{
  "expo": {
    "name": "Wired Build",
    "slug": "wired-build",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "wiredbuilddemo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.wiredautogroup.wiredbuild",
      "associatedDomains": [
        "applinks:wiredbuild.app",
        "applinks:www.wiredbuild.app"
      ]
    },
    "android": {
      "package": "com.wiredautogroup.wiredbuild",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "wiredbuild.app",
              "pathPrefix": "/build"
            },
            {
              "scheme": "https",
              "host": "www.wiredbuild.app",
              "pathPrefix": "/build"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "adaptiveIcon": {
        "backgroundColor": "#08090B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#08090B",
          "dark": {
            "backgroundColor": "#08090B"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Wired Build to use the camera to scan VIN barcodes on your vehicle.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Wired Build to access your photos to set profile and mod images.",
          "cameraPermission": "Allow Wired Build to use the camera for profile photos and VIN scans."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#F5A524"
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
