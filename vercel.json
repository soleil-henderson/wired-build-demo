{
  "buildCommand": "node scripts/build-web.mjs",
  "outputDirectory": "dist",
  "framework": null,
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "header", "key": "x-forwarded-proto", "value": "http" }],
      "destination": "https://wiredbuild.com/:path*",
      "permanent": true
    },
    {
      "source": "/build/:path*",
      "destination": "/app/build/:path*",
      "permanent": true
    },
    {
      "source": "/legal/:path*",
      "destination": "/app/legal/:path*",
      "permanent": true
    },
    {
      "source": "/workshop/:path*",
      "destination": "/app/workshop/:path*",
      "permanent": true
    },
    {
      "source": "/auth/:path*",
      "destination": "/app/auth/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/:path*", "destination": "/app/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ]
}
