# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit real keys.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxx

# Base URL used when sharing build pages (e.g. https://wiredbuild.app).
# Falls back to https://wiredbuild.app in code when unset.
EXPO_PUBLIC_SITE_URL=https://wiredbuild.app
