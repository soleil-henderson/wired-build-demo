# Copy to .env — never commit real keys.

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Marketing site origin (landing at /, app at /app on web)
EXPO_PUBLIC_SITE_URL=https://wiredbuild.com

# Supabase Edge Function secrets (set via supabase secrets set)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# STRIPE_PRICE_MEMBER=price_xxx
# STRIPE_PRICE_PRO=price_xxx
# STRIPE_PRICE_WORKSHOP=price_xxx
# STRIPE_IDENTITY_WEBHOOK_SECRET=whsec_xxx
# REDBOOK_API_KEY=
# KBB_API_KEY=
# APPLE_IAP_SHARED_SECRET= (optional, for verify-iap)

# SERPAPI_KEY=  (Google Shopping alternatives in resolve-product)
# ANTHROPIC_API_KEY=  (Wired AI — set via supabase secrets set)
# EXPO_PUBLIC_POSTHOG_KEY=

# Supabase Edge Function secrets (events + locations)
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM_EMAIL=Wired Build <events@wiredbuild.app>

# npx supabase secrets set RESEND_API_KEY=your_resend_api_key
